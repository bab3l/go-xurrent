# Copy to .env and fill in (do not commit .env).
# Load before running integration tests, e.g. PowerShell:
#   Get-Content .env | ForEach-Object { if ($_ -match '^\s*([^#][^=]*)=(.*)$') { Set-Item -Path "env:$($matches[1])" -Value $matches[2].Trim() } }
# Or use direnv / your IDE env loader.

# Required for authenticated production smoke tests (see test/integration/production_smoke_test.go)
XURRENT_TOKEN=
XURRENT_ACCOUNT=

# Optional: existing problem id in your tenant for GET /v1/problems/{id}
XURRENT_TEST_PROBLEM_ID=
